# --- Build output ---
/rt-node-agent
/rt-node-agent.exe
/bin/
/dist/
/build/
*.exe
*.dll
*.so
*.dylib

# Go tooling
*.test
*.out
coverage.*
coverage.txt
profile.cov
cpu.prof
mem.prof
/vendor/

# --- Secrets: see CLAUDE.md §Public-repo hygiene ---
# This block is the safety rail, not the contract. The rule is: if it
# would feel wrong to paste into a public Slack, add a pattern HERE
# before creating the file. `git log -p --all` is also public — a
# committed secret is compromised; rotate, don't rewrite.

# Environment / token files
.env
.env.*
!.env.example
token
token.txt
*.token
secrets/
secrets.*

# Private keys, certs, signatures (cosign/minisign/SSH/TLS/GPG)
*.pem
*.key
*.pfx
*.p12
*.priv
*.crt
*.cer
*.der
*.csr
*.jks
*.keystore
*.truststore
*.gpg
*.asc
*.pgp
cosign.key
minisign.key
*.minisig
known_hosts
authorized_keys
id_rsa*
id_ed25519*
id_ecdsa*

# Anywhere a real host might dump its agent-state into the working tree
/etc/
/var/

# --- Operator-owned config ---
# config.local.* and the on-disk live config never belong in the repo.
config.local.*
/config.yaml
!examples/config.yaml

# Migration intermediates. Both `.new` (legacy v0.2.0-v0.2.6 sidecar) and
# `.bak` (v0.2.7+ in-place migration backup) live alongside the live
# config and should never be committed.
*.yaml.new
*.yaml.bak
*.yaml.broken-*
config.yaml.new
config.yaml.bak
training_mode.json
*.pid

# --- Scratch files / operator notes ---
# Leading-space markdown files and SCRATCH.*/scratch.* are explicitly
# excluded so accidental operator notes don't slip in.
[ ]*.md
scratch.*
SCRATCH.*
NOTES.*
TODO.*.md
*.todo.md

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
*.orig
*.rej
.fleet/
.zed/

# --- Python tooling (if anyone wires up local scripts) ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- Claude Code agent state ---
# CLAUDE.md is committed (it's the public contract for AI collaborators,
# content-equivalent to CONTRIBUTING.md). Everything ELSE under
# .claude/ is local agent state with user-specific paths/transcripts.
.claude/settings.local.json
.claude/memory/
.claude/projects/
.claude/transcripts/
.claude/*.local.*
