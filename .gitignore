# Binaries and build output
/rt-node-agent
/rt-node-agent.exe
/bin/
/dist/
/build/
*.exe
*.dll
*.so
*.dylib

# Go test / coverage
*.test
*.out
coverage.*
/vendor/

# Secrets — see CLAUDE.md §Public-repo hygiene
# Never commit tokens, keys, or any /etc/rt-node-agent/token content
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
token
token.txt
*.token
secrets/
/etc/
/var/

# Release signing material (cosign/minisign private keys)
*.priv
cosign.key
minisign.key

# Local dev config that may contain real node URLs or tokens
config.local.*
/config.yaml
!examples/config.yaml

# Operator working files — produced by `config migrate` or hand-edits.
# A *.new file represents an unreviewed config diff; not committable.
*.yaml.new
*.yaml.bak
config.yaml.new
training_mode.json

# Scratch markdown (anything starting with a space, or named scratch.*)
# Keeps accidental operator notes out of commits.
[ ]*.md
scratch.*
SCRATCH.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Claude Code local settings (may contain user-specific paths/tokens).
# Note: CLAUDE.md itself IS committed — it documents the public contract
# and is content-equivalent to CONTRIBUTING.md. Nothing sensitive there.
.claude/settings.local.json
.claude/*.local.*
